###############
# cargo chef
###############
FROM public.ecr.aws/docker/library/rust:1.91.1-bookworm AS chef

# Install any custom CA certificates from the certs named context.
RUN --mount=type=bind,from=certs,target=/usr/local/share/ca-certificates/ \
    update-ca-certificates -v

COPY assets/apt/apt-retry.conf /etc/apt/apt.conf.d/apt-retry.conf
COPY assets/apt/debian.sources /etc/apt/sources.list.d/debian.sources
# Remove default sources.list to use only our fallback-enabled sources
RUN rm -f /etc/apt/sources.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends libclang-dev pkg-config && \
    rm -rf /var/lib/apt/lists/*
RUN cargo install cargo-chef@0.1.73

FROM chef AS planner

WORKDIR /src
COPY . .

# Prepare the recipe for cargo-chef, essentially the dependency graph
RUN cargo chef prepare --bin arc-node-execution --recipe-path arc-node-execution-recipe.json

###############
# builder image
###############
FROM chef AS builder

# Create a non-root user 'arc' with UID/GID 999. This method is used because distroless images lack user management tools like 'useradd'.
# The user's home directory is set to /data and shell to /bin/false for security.
RUN printf 'arc:x:999:999::/data:/bin/false\n' > /tmp/passwd && \
    printf 'arc:x:999:\n' > /tmp/group

# Build-time args that are stable across commits — placed before dep-cook so the
# cook layer's S3 cache entry survives commits that only change git metadata.
ARG BUILD_PROFILE=release
ARG FEATURES="default"
ARG CHAIN=""
ARG RUSTFLAGS=""

# Set environment variables for the build process.
ENV CARGO_HOME=/usr/local/cargo
ENV CARGO_NET_GIT_FETCH_WITH_CLI=true
ENV CARGO_HTTP_CAINFO=/etc/ssl/certs/ca-certificates.crt
ENV RUSTFLAGS=$RUSTFLAGS

WORKDIR /app

COPY --from=planner /src/arc-node-execution-recipe.json arc-node-execution-recipe.json
RUN --mount=type=cache,id=reth-cargo-registry,sharing=locked,target=/usr/local/cargo/registry \
    --mount=type=cache,id=reth-cargo-git,sharing=locked,target=/usr/local/cargo/git \
    --mount=type=cache,id=reth-cargo-target,sharing=locked,target=/app/target \
    # Cook the recipe produced by the planner, namely compile dependencies
    cargo chef cook --bin arc-node-execution --profile $BUILD_PROFILE --features "$FEATURES" --recipe-path arc-node-execution-recipe.json

# Per-commit git version args come after dep-cook — moving them here prevents the
# new commit hash from busting the cook layer's S3 cache key on every push.
ARG GIT_COMMIT_HASH="0000000000000000000000000000000000000000"
ARG GIT_VERSION="v0.0.0-unknown"
ARG GIT_SHORT_HASH="00000000"
ARG ARC_IDEMPOTENT_BUILD=false
ENV VERGEN_GIT_SHA=$GIT_COMMIT_HASH
ENV VERGEN_GIT_DESCRIBE=$GIT_VERSION
ENV VERGEN_GIT_SHA_SHORT=$GIT_SHORT_HASH
ENV ARC_IDEMPOTENT_BUILD=$ARC_IDEMPOTENT_BUILD

COPY . .

# Use BuildKit cache mounts for Cargo dependencies and build artifacts
# This significantly speeds up subsequent builds by caching:
# - Cargo registry (downloaded crates)
# - Cargo git dependencies
# - Build target directory (compiled artifacts)
RUN --mount=type=cache,id=reth-cargo-registry,sharing=locked,target=/usr/local/cargo/registry \
    --mount=type=cache,id=reth-cargo-git,sharing=locked,target=/usr/local/cargo/git \
    --mount=type=cache,id=reth-cargo-target,sharing=locked,target=/app/target \
    cargo build --bin arc-node-execution --bin arc-snapshots --profile $BUILD_PROFILE --features "$FEATURES" --locked && \
    # Cargo outputs 'dev' profile to 'debug' directory, but other profiles use their own name
    if [ "$BUILD_PROFILE" = "dev" ]; then TARGET_DIR="debug"; else TARGET_DIR="$BUILD_PROFILE"; fi && \
    cp /app/target/$TARGET_DIR/arc-node-execution /tmp/arc-node-execution && \
    cp /app/target/$TARGET_DIR/arc-snapshots /tmp/arc-snapshots

#######################
# release runtime image
#######################
FROM gcr.io/distroless/cc-debian12:nonroot AS release-runtime

COPY --from=chef /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt

# Copy user information from the builder stage into the runtime image.
COPY --from=builder /tmp/passwd /etc/passwd
COPY --from=builder /tmp/group /etc/group
# Copy application binaries from the builder stage into the final image.
COPY --from=builder /tmp/arc-node-execution /usr/local/bin/arc-node-execution
COPY --from=builder /tmp/arc-snapshots /usr/local/bin/arc-snapshots

# Expose Reth RPC, WS, AuthRPC, and metrics ports
EXPOSE 8545 8546 8551 9001 6061

USER arc

ENTRYPOINT ["/usr/local/bin/arc-node-execution"]

###################
# dev runtime image
###################
FROM public.ecr.aws/docker/library/debian:bookworm-slim AS dev-runtime

COPY --from=chef /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt

# Configure apt-get with retry logic and fallback mirrors for CI reliability
COPY assets/apt/apt-retry.conf /etc/apt/apt.conf.d/apt-retry.conf
COPY assets/apt/debian.sources /etc/apt/sources.list.d/debian.sources

# Install iptables and tc for chaos testing
RUN rm -f /etc/apt/sources.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends iptables iproute2 && \
    rm -rf /var/lib/apt/lists/*

# Copy application binaries from the builder stage into the final image.
COPY --from=builder /tmp/arc-node-execution /usr/local/bin/arc-node-execution
COPY --from=builder /tmp/arc-snapshots /usr/local/bin/arc-snapshots

EXPOSE 8545 8546 8551 9001 6061 30303

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["node", "--http", "--http.api=all", "--chain=/root/assets/genesis.json", "--http.port=8545", "--authrpc.port=8551", "--metrics=0.0.0.0:9001", "--port=30303", "--discovery.port=30303"]
